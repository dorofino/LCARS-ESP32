{
    "name": "lcars-esp32",
    "version": "0.1.0",
    "description": "LCARS Star Trek UI rendering engine for ESP32-S3 + TFT_eSPI. Procedural anti-aliased elbows, bars, sidebars, widgets, animations, and color themes.",
    "keywords": "lcars, star-trek, tft, esp32, ui, tft_espi, gui",
    "repository": {
        "type": "git",
        "url": "https://github.com/dorofino/lcars-esp32.git"
    },
    "authors": [
        {
            "name": "dorofino",
            "url": "https://github.com/dorofino"
        }
    ],
    "license": "MIT",
    "frameworks": ["arduino"],
    "platforms": ["espressif32"],
    "dependencies": {
        "bodmer/TFT_eSPI": "^2.5.0"
    },
    "build": {
        "srcDir": "src",
        "srcFilter": ["+<*>", "-<../examples/>"]
    },
    "export": {
        "exclude": ["examples", "boards", "flash.ps1", ".gitignore"]
    }
}
